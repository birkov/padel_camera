<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow cleartext for RTMP streaming to YouTube -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">a.rtmp.youtube.com</domain>
        <domain includeSubdomains="true">b.rtmp.youtube.com</domain>
    </domain-config>
    <base-config cleartextTrafficPermitted="false" />
</network-security-config>
